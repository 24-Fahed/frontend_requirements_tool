{
  "layouts": [
    {
      "id": "home-default",
      "name": "首页默认布局",
      "nodes": [
        {
          "id": "root",
          "type": "VStack",
          "props": { "gap": 0, "padding": 0 },
          "children": [
            { "id": "nav", "type": "NavBar", "props": { "title": "首页", "leftText": "", "rightText": "" } },
            { "id": "notice", "type": "NoticeBar", "props": { "text": "欢迎光临，新品上架中" } },
            { "id": "banner", "type": "Image", "props": { "src": "placeholder", "width": "100%", "height": 160, "radius": 0 } },
            { "id": "search", "type": "Search", "props": { "placeholder": "搜索商品" } },
            { "id": "title1", "type": "TextBlock", "props": { "content": "热门推荐", "fontSize": 16, "color": "#323233", "bold": "true", "align": "left" } },
            {
              "id": "products",
              "type": "HStack",
              "props": { "gap": 8 },
              "children": [
                { "id": "p1", "type": "ProductCard", "props": { "title": "商品A", "desc": "热销商品", "price": "¥99.00", "imageHeight": 120 } },
                { "id": "p2", "type": "ProductCard", "props": { "title": "商品B", "desc": "新品上市", "price": "¥128.00", "imageHeight": 120 } }
              ]
            },
            { "id": "tabbar", "type": "TabBar", "props": { "items": "首页,分类,购物车,我的" } }
          ]
        }
      ]
    },
    {
      "id": "product-list",
      "name": "商品列表页",
      "nodes": [
        {
          "id": "root",
          "type": "VStack",
          "props": { "gap": 0, "padding": 0 },
          "children": [
            { "id": "nav", "type": "NavBar", "props": { "title": "商品列表", "leftText": "返回", "rightText": "" } },
            { "id": "search", "type": "Search", "props": { "placeholder": "搜索商品" } },
            {
              "id": "grid",
              "type": "Grid2Col",
              "props": { "gap": 8 },
              "children": [
                { "id": "p1", "type": "ProductCard", "props": { "title": "商品1", "desc": "热销", "price": "¥59.00", "imageHeight": 100 } },
                { "id": "p2", "type": "ProductCard", "props": { "title": "商品2", "desc": "新品", "price": "¥79.00", "imageHeight": 100 } },
                { "id": "p3", "type": "ProductCard", "props": { "title": "商品3", "desc": "特价", "price": "¥39.00", "imageHeight": 100 } },
                { "id": "p4", "type": "ProductCard", "props": { "title": "商品4", "desc": "推荐", "price": "¥99.00", "imageHeight": 100 } }
              ]
            },
            { "id": "tabbar", "type": "TabBar", "props": { "items": "首页,分类,购物车,我的" } }
          ]
        }
      ]
    },
    {
      "id": "profile-default",
      "name": "个人中心页",
      "nodes": [
        {
          "id": "root",
          "type": "VStack",
          "props": { "gap": 0, "padding": 0 },
          "children": [
            { "id": "nav", "type": "NavBar", "props": { "title": "个人中心", "leftText": "", "rightText": "设置" } },
            { "id": "avatar", "type": "Image", "props": { "src": "placeholder", "width": "64px", "height": 64, "radius": 32 } },
            { "id": "username", "type": "TextBlock", "props": { "content": "用户昵称", "fontSize": 16, "color": "#323233", "bold": "true", "align": "center" } },
            { "id": "cell1", "type": "Cell", "props": { "title": "我的订单", "value": "查看全部", "isLink": "true" } },
            { "id": "cell2", "type": "Cell", "props": { "title": "收货地址", "value": "", "isLink": "true" } },
            { "id": "cell3", "type": "Cell", "props": { "title": "联系客服", "value": "", "isLink": "true" } },
            { "id": "cell4", "type": "Cell", "props": { "title": "关于我们", "value": "", "isLink": "true" } },
            { "id": "tabbar", "type": "TabBar", "props": { "items": "首页,分类,购物车,我的" } }
          ]
        }
      ]
    },
    {
      "id": "form-default",
      "name": "表单页",
      "nodes": [
        {
          "id": "root",
          "type": "VStack",
          "props": { "gap": 0, "padding": 0 },
          "children": [
            { "id": "nav", "type": "NavBar", "props": { "title": "信息填写", "leftText": "返回", "rightText": "" } },
            { "id": "input1", "type": "Input", "props": { "label": "姓名", "placeholder": "请输入姓名", "inputType": "text" } },
            { "id": "input2", "type": "Input", "props": { "label": "电话", "placeholder": "请输入手机号", "inputType": "tel" } },
            { "id": "input3", "type": "Input", "props": { "label": "备注", "placeholder": "请输入备注信息", "inputType": "text" } },
            { "id": "btn", "type": "Button", "props": { "text": "提交", "type": "primary", "size": "large", "block": "true" } }
          ]
        }
      ]
    }
  ]
}
