@startuml 交互式需求收集子系统_模块图
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName SimHei
skinparam NoteFontName SimHei
skinparam PackageFontName SimHei
skinparam RectangleFontName SimHei
skinparam TitleFontName SimHei
skinparam LegendFontName SimHei
skinparam ComponentFontName SimHei
skinparam ArrowColor #333333
skinparam PackageFontSize 14
skinparam ComponentFontSize 13

title 交互式需求收集子系统 - 模块图（v0.1.2）

package "交互式需求收集子系统" as INT_SYS #FFF3E0 {

  package "模拟器模块" as MOD_SIM #FFE0B2 {
    component [PhoneFrame] as PHONE_FRAME
    component [SimNode] as SIM_NODE
    note left of MOD_SIM
      职责：手机外壳渲染
      和内部组件递归渲染
    end note
  }

  package "组件面板模块" as MOD_PANEL #FFE0B2 {
    component [ComponentPanel] as COMP_PANEL
    component [PanelPreview] as PANEL_PREVIEW
    note right of MOD_PANEL
      职责：展示组件和布局列表，
      vuedraggable pull:clone
      拖入模拟器容器
    end note
  }

  package "组件管理模块" as MOD_COMP #FFE0B2 {
    component [ComponentLoader] as COMP_LOADER
    note left of MOD_COMP
      职责：动态加载开发者
      提供的组件库文件
    end note
  }

  package "布局管理模块" as MOD_LAYOUT #FFE0B2 {
    component [LayoutResolver] as LAYOUT_RESOLVER
    note right of MOD_LAYOUT
      职责：解析默认布局
      方案到节点树
    end note
  }

  package "结果序列化模块" as MOD_SER #FFE0B2 {
    component [ResultSerializer] as SERIALIZER
    note left of MOD_SER
      职责：将模拟器编辑状态
      序列化为结构化JSON
    end note
  }
}

' 模块间关系
MOD_COMP --> MOD_SIM : 提供运行时组件
MOD_COMP --> MOD_PANEL : 提供预览组件
MOD_PANEL --> MOD_SIM : vuedraggable clone 拖入
MOD_LAYOUT --> MOD_SIM : 提供默认布局方案
MOD_SER --> MOD_SIM : 读取编辑状态

@enduml
