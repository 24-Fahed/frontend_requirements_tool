@startuml 子系统接口图
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName SimHei
skinparam NoteFontName SimHei
skinparam PackageFontName SimHei
skinparam RectangleFontName SimHei
skinparam TitleFontName SimHei
skinparam LegendFontName SimHei
skinparam ComponentFontName SimHei
skinparam InterfaceFontName SimHei
skinparam ArrowColor #333333
skinparam PackageFontSize 14
skinparam ComponentFontSize 12

title 需求收集工具 - 子系统接口图

' === 界面子系统 ===
package "界面子系统" as UI_SYS #F3E5F5 {
  interface "I_Navigation" as I_NAV {
    switchCategory(categoryId: string): void
    toggleDrawer(): void
  }
  interface "I_Layout" as I_LAYOUT {
    setSimulatorVisible(visible: boolean): void
    setContentData(data: object): void
  }
}

' === 交互式需求收集子系统 ===
package "交互式需求收集子系统" as INT_SYS #FFF3E0 {
  interface "I_Simulator" as I_SIM {
    loadDefault(designId: string): void
    open(questionId: string): void
    getResult(): JSON
    reset(): void
  }
  interface "I_ComponentRegistry" as I_COMP_REG {
    registerComponents(config: JSON): void
    getComponentList(): ComponentInfo[]
  }
  interface "I_LayoutRegistry" as I_LAYOUT_REG {
    registerLayouts(config: JSON): void
    getLayoutList(): LayoutInfo[]
  }
}

' === 需求收集子系统（前端） ===
package "需求收集子系统（前端）" as REQ_FE_SYS #E8F5E9 {
  interface "I_RequirementCollector" as I_REQ_COLL {
    loadRequirements(categoryId: string): void
    collectAnswer(questionId: string, answer: any): void
    exportResults(): JSON
    submitResults(): Promise
  }
  interface "I_TableRenderer" as I_TABLE {
    renderTable(data: RequirementData): void
    onAnswerChange(callback: Function): void
  }
}

' === 需求收集子系统（后端） ===
package "需求收集子系统（后端）" as REQ_BE_SYS #FFF9C4 {
  interface "I_ParseService" as I_PARSE {
    GET /api/requirements: RequirementData
    GET /api/components: ComponentConfig
    GET /api/default-layout: LayoutData
  }
  interface "I_StorageService" as I_STORAGE {
    POST /api/results: SaveResult
    GET /api/results: RequirementResult
  }
  interface "I_StaticService" as I_STATIC {
    GET /static/lib/{path}: File
  }
}

' === 接口调用关系 ===

UI_SYS --> I_NAV : 提供
UI_SYS --> I_LAYOUT : 提供

REQ_FE_SYS --> I_REQ_COLL : 提供
REQ_FE_SYS --> I_TABLE : 提供

INT_SYS --> I_SIM : 提供
INT_SYS --> I_COMP_REG : 提供
INT_SYS --> I_LAYOUT_REG : 提供

REQ_BE_SYS --> I_PARSE : 提供
REQ_BE_SYS --> I_STORAGE : 提供
REQ_BE_SYS --> I_STATIC : 提供

' 调用关系（虚线）
I_NAV ..> I_REQ_COLL : 界面调用需求收集
I_LAYOUT ..> I_SIM : 界面嵌入模拟器
I_REQ_COLL ..> I_SIM : 需求收集调用交互式收集
I_REQ_COLL ..> I_PARSE : 前端请求后端解析服务
I_REQ_COLL ..> I_STORAGE : 前端请求后端存储服务
I_COMP_REG ..> I_PARSE : 加载组件配置
I_LAYOUT_REG ..> I_PARSE : 加载布局配置
I_SIM ..> I_STATIC : 加载组件库文件

legend right
  |= 调用方 |= 接口 |= 提供方 |= 方式 |
  | 界面子系统 | I_Navigation | 需求收集子系统(前端) | Vue emit |
  | 界面子系统 | I_Layout | 交互式需求收集子系统 | Vue props/emit |
  | 需求收集(前端) | I_Simulator | 交互式需求收集子系统 | Vue组件调用 |
  | 需求收集(前端) | I_ParseService | 需求收集(后端) | HTTP GET |
  | 需求收集(前端) | I_StorageService | 需求收集(后端) | HTTP POST/GET |
  | 交互式需求收集 | I_StaticService | 需求收集(后端) | HTTP GET |
end legend

@enduml
