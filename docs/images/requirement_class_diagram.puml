@startuml 需求收集子系统_类图
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName SimHei
skinparam NoteFontName SimHei
skinparam PackageFontName SimHei
skinparam ClassFontName SimHei
skinparam TitleFontName SimHei
skinparam LegendFontName SimHei
skinparam ArrowColor #333333
skinparam ClassFontSize 12
skinparam ClassAttributeFontSize 11
skinparam ClassMethodFontSize 11

title 需求收集子系统 - 构件图（类图）

' ======= 前端 =======

package "需求收集子系统（前端）" as REQ_FE #E8F5E9 {

  ' 表格渲染模块
  package "表格渲染模块" as MOD_TABLE #C8E6C9 {

    class TableRenderer {
      + category: Category {prop}
      - appStore: useAppStore
      - simStore: useSimulatorStore
      + render(): VNode
    }

    class QuestionRow {
      + question: Object {prop}
      + categoryId: string {prop}
      - appStore: useAppStore
      - simStore: useSimulatorStore
      + currentAnswer: Answer | null {computed}
      + handleTextChange(): void
      + handleOptionSelect(): void
      + handleCustomInput(): void
      + handleInteractive(): void
      + saveInteractiveResult(): void
    }
  }

  ' 应用状态仓库（承载配置加载、回答收集、结果导出）
  package "应用状态仓库" as MOD_APP #C8E6C9 {

    class useAppStore {
      + requirementData: any
      + categories: Category[] {computed}
      + projectInfo: object {computed}
      + componentList: ComponentInfo[]
      + layoutList: ComponentInfo[]
      + defaultLayouts: any[]
      + activeCategoryId: string
      + answers: object
      + loadRequirements(): Promise<void>
      + loadComponents(): Promise<void>
      + loadDefaultLayouts(): Promise<void>
      + setCategory(categoryId: string): void
      + setAnswer(questionId: string, answer: Answer): void
      + getAnswer(questionId: string): Answer | null
      + submitResults(): Promise<void>
      + loadResults(): Promise<void>
    }
  }
}

' ======= 后端 =======

package "需求收集子系统（后端）" as REQ_BE #FFF9C4 {

  ' 数据模型模块
  package "数据模型模块" as MOD_MODEL #FFFDE7 {

    class RequirementDataModel {
      + project: ProjectModel
      + categories: list[CategoryModel]
    }

    class CategoryModel {
      + id: str
      + name: str
      + order: int
      + questions: list[QuestionModel]
    }

    class QuestionModel {
      + id: str
      + text: str
      + purpose: str
      + type: str
      + options: list[str] | None
      + allowCustom: bool
      + interactiveConfig: InteractiveConfig | None
      + note: str | None
    }

    class InteractiveConfig {
      + defaultLayout: str | None
    }

    class AnswerModel {
      + categoryId: str
      + questionId: str
      + type: str
      + value: Any
      + customValue: str | None
    }

    class ResultModel {
      + project: dict
      + submittedAt: str
      + answers: list[AnswerModel]
    }
  }

  ' 文件解析模块
  package "文件解析模块" as MOD_PARSE #FFFDE7 {

    class YamlParser {
      + parse_requirements(file_path: str): RequirementDataModel
    }

    class JsonParser {
      + parse_components(file_path: str): dict
      + parse_layouts(file_path: str): dict
      + parse_default_layout(file_path: str, layout_id: str): dict
    }
  }

  ' 需求存储模块
  package "需求存储模块" as MOD_STORE #FFFDE7 {

    class ResultStorage {
      - output_dir: str
      - yaml_writer: YamlWriter
      + save(result: ResultModel): void
      + load(): dict | None
    }

    class YamlWriter {
      + write_yaml(data: ResultModel, file_path: str): void
      + write_json(data: ResultModel, file_path: str): void
    }
  }

  ' 静态资源模块
  package "静态资源模块" as MOD_STATIC #FFFDE7 {

    class StaticFileServer {
      + get_file(path: str): FileResponse
      + list_files(dir_path: str): list[str]
    }
  }
}

' ======= 前端数据类 =======
class Answer {
  + questionId: string
  + categoryId: string
  + type: string
  + value: string | string[] | { nodes: LayoutNode[] }
  + customValue: string | undefined
}

' ======= 关系 =======
' 前端内部
TableRenderer *-- QuestionRow : 包含多个
QuestionRow --> useAppStore : setAnswer / getAnswer
QuestionRow --> useSimulatorStore : loadDefault / getResult
useAppStore o-- Answer : 管理回答映射

' 后端内部
RequirementDataModel *-- CategoryModel : 包含
CategoryModel *-- QuestionModel : 包含
ResultModel *-- AnswerModel : 包含
YamlParser --> RequirementDataModel : 输出
JsonParser --> CategoryModel : 输出
ResultStorage --> YamlWriter : 使用
ResultStorage --> ResultModel : 输入
YamlWriter --> ResultModel : 输入

@enduml
