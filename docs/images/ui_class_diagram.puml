@startuml 界面子系统_类图
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName SimHei
skinparam NoteFontName SimHei
skinparam PackageFontName SimHei
skinparam ClassFontName SimHei
skinparam TitleFontName SimHei
skinparam LegendFontName SimHei
skinparam ArrowColor #333333
skinparam ClassFontSize 12
skinparam ClassAttributeFontSize 11
skinparam ClassMethodFontSize 11

title 界面子系统 - 构件图（类图）（v0.1.2）

package "界面子系统" as UI_SYS #F3E5F5 {

  ' 顶部工具栏模块
  package "顶部工具栏模块" as MOD_HEADER #E1BEE7 {

    class AppHeader {
      - store: useAppStore
      + toggleSidebar(): void
      + togglePanel(): void
      + toggleSimulator(): void
      + handleExport(): Promise<void>
      + render(): VNode
    }
  }

  ' 侧边栏模块
  package "侧边栏模块" as MOD_SIDEBAR #E1BEE7 {

    class SideBar {
      - store: useAppStore
      + sortedCategories: Category[] {computed}
      + selectCategory(id: string): void
      + render(): VNode
    }
  }

  ' 内容展示区模块
  package "内容展示区模块" as MOD_CONTENT #E1BEE7 {

    class ContentArea {
      - store: useAppStore
      + activeCategory: Category | null {computed}
      + render(): VNode
    }
  }

  ' 模拟器区域模块
  package "模拟器区域模块" as MOD_SIM_AREA #E1BEE7 {

    class SimulatorArea {
      - store: useAppStore
      + render(): VNode
    }
  }
}

' === 关系 ===
AppHeader --> SideBar : 通过 store 控制折叠
AppHeader --> SimulatorArea : 通过 store 控制显隐

note bottom of AppHeader
  togglePanel() 通过共享状态仓库
  控制 ComponentPanel 的显隐，
  ComponentPanel 属于交互式需求收集子系统
end note

note bottom of SimulatorArea
  静态导入并渲染 PhoneFrame 和 ComponentPanel，
  ComponentPanel 属于交互式需求收集子系统
end note

@enduml
