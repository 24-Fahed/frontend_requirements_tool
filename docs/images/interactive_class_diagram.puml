@startuml 交互式需求收集子系统_类图
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName SimHei
skinparam NoteFontName SimHei
skinparam PackageFontName SimHei
skinparam ClassFontName SimHei
skinparam TitleFontName SimHei
skinparam LegendFontName SimHei
skinparam ArrowColor #333333
skinparam ClassFontSize 12
skinparam ClassAttributeFontSize 11
skinparam ClassMethodFontSize 11

title 交互式需求收集子系统 - 构件图（类图）（v0.1.2）

' === 模拟器模块 ===
package "模拟器模块" as MOD_SIM #FFE0B2 {

  class PhoneFrame {
    - width: number
    - height: number
    - statusBarText: string
    + render(): VNode
  }

  class SimNode {
    - node: LayoutNode
    - metaMap: Map<string, ComponentInfo>
    - selectedNodeId: string
    - runtimeComponent: Component
    + meta: ComponentInfo {computed}
    + isContainer: boolean {computed}
    + normalizedProps: object {computed}
    + render(): VNode
  }
}

' === 组件面板模块 ===
package "组件面板模块" as MOD_PANEL #FFE0B2 {

  class ComponentPanel {
    - open: boolean
    - activeTab: "component" | "layout"
    + toggle(): void
    + setActiveTab(tab: string): void
    + close(): void
    + metaToNode(meta: ComponentInfo): LayoutNode
    + render(): VNode
  }

  class PanelPreview {
    - meta: ComponentInfo
    - runtimeComponent: Component
    + previewProps: object {computed}
    + loadPreviewComponent(): Promise
    + render(): VNode
  }
}

' === 组件管理模块 ===
package "组件管理模块" as MOD_COMP #FFE0B2 {

  class ComponentLoader {
    - loadedLibs: Map<string, object>
    - runtimeComponentCache: Map<string, Component>
    + preloadLibraries(metas: ComponentInfo[]): Promise
    + resolve(meta: ComponentInfo): Promise<Component>
    - loadScriptLibrary(sourceFile: string): Promise<object>
    - createContainerComponent(tag: string): Component
    - injectStyle(styleId: string, cssText: string): void
  }

  class ComponentInfo {
    + name: string
    + label: string
    + category: string
    + icon: string
    + props: PropDef[]
    + defaultProps: object
    + sourceFile: string
    + componentTag: string
    + isContainer: boolean
    + maxChildren: number
  }

  class PropDef {
    + name: string
    + type: string
    + options: string[]
    + default: any
    + label: string
  }
}

' === 布局管理模块 ===
package "布局管理模块" as MOD_LAYOUT #FFE0B2 {

  class LayoutResolver {
    + resolve(defaultLayoutId: string): LayoutNode[]
    + createNode(type: string, props: object): LayoutNode
    + cloneTree(nodes: LayoutNode[]): LayoutNode[]
  }
}

' === 结果序列化模块 ===
package "结果序列化模块" as MOD_SER #FFE0B2 {

  class ResultSerializer {
    + serialize(nodeTree: LayoutNode[]): object
    + deserialize(data: object): LayoutNode[]
  }
}

' === 通用数据类 ===
class LayoutNode {
  + id: string
  + type: string
  + props: object
  + children: LayoutNode[]
}

' === 关系 ===
PhoneFrame *-- SimNode : 渲染根节点
SimNode o-- LayoutNode : 递归渲染
SimNode --> ComponentLoader : 解析运行时组件
ComponentPanel *-- PanelPreview : 渲染预览
PanelPreview --> ComponentLoader : 解析预览组件
ComponentInfo *-- PropDef : 包含
ResultSerializer --> LayoutNode : 序列化

note right of SimNode
  容器节点的子节点排序
  由 vuedraggable 处理，
  SimNode 只负责渲染
end note

note right of ComponentPanel
  vuedraggable pull: clone, group: sim
  拖出时 metaToNode() 将
  ComponentInfo 转为 LayoutNode
  直接插入 SimNode 容器的
  node.children 响应式数组
end note

@enduml
