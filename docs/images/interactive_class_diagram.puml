@startuml 交互式需求收集子系统_类图
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName SimHei
skinparam NoteFontName SimHei
skinparam PackageFontName SimHei
skinparam ClassFontName SimHei
skinparam TitleFontName SimHei
skinparam LegendFontName SimHei
skinparam ArrowColor #333333
skinparam ClassFontSize 12
skinparam ClassAttributeFontSize 11
skinparam ClassMethodFontSize 11

title 交互式需求收集子系统 - 构件图（类图）（v0.1.3）

' === 模拟器模块 ===
package "模拟器模块" as MOD_SIM #FFE0B2 {

  class PhoneFrame {
    - simStore: useSimulatorStore
    - appStore: useAppStore
    + allMetas: ComponentInfo[] {computed}
    + metaMap: Map<string, ComponentInfo> {computed}
    + selectNode(nodeId: string): void
    + render(): VNode
  }

  class SimNode {
    - node: LayoutNode {prop}
    - metaMap: Map<string, ComponentInfo> {prop}
    - selectedNodeId: string {prop}
    - runtimeComponent: Component {shallowRef}
    + meta: ComponentInfo {computed}
    + isContainer: boolean {computed}
    + isSelected: boolean {computed}
    + isBuiltinContainer: boolean {computed}
    + containerStyle: object {computed}
    + normalizedProps: object {computed}
    + loadRuntimeComponent(): Promise<void>
    + emit("select", nodeId: string): void
    + emit("delete", nodeId: string): void
    + render(): VNode
  }
}

' === 组件面板模块 ===
package "组件面板模块" as MOD_PANEL #FFE0B2 {

  class ComponentPanel {
    - appStore: useAppStore
    - simStore: useSimulatorStore
    - activeTab: string
    + previewMetas: ComponentInfo[] {computed}
    + metaToNode(meta: ComponentInfo): LayoutNode
    + PanelPreview: defineComponent {内联}
    + render(): VNode
  }

  class PanelPreview {
    - meta: ComponentInfo {prop}
    - runtimeComponent: Component {shallowRef}
    + previewProps: object {computed}
    + loadPreviewComponent(): Promise<void>
    + render(): VNode
  }
}

' === 组件管理模块 ===
package "组件管理模块" as MOD_COMP #FFE0B2 {

  class ComponentLoader {
    - runtimeComponentCache: Map<string, Component>
    + preloadComponentLibraries(metas: ComponentInfo[]): Promise<void>
    + resolveRuntimeComponent(meta: ComponentInfo): Promise<Component | null>
    - createContainerComponent(tag: string): Component | null
    - normalizeSourcePath(sourceFile: string): string
    - ensureVantLoaded(): Promise<void>
    - injectGlobalStyles(): void
    - createSfcLoaderOptions(): object
  }

  class ComponentInfo {
    + name: string
    + label: string
    + category: string
    + icon: string
    + props: PropDef[]
    + defaultProps: object
    + sourceFile: string
    + componentTag: string
    + isContainer: boolean
    + maxChildren: number
  }

  class PropDef {
    + name: string
    + type: string
    + options: string[]
    + default: any
    + label: string
  }
}

' === 模拟器状态仓库 ===
package "模拟器状态仓库" as MOD_STORE #FFE0B2 {

  class useSimulatorStore {
    + nodeTree: LayoutNode[]
    + currentQuestionId: string
    + selectedNodeId: string
    + generateId(): string
    + loadDefault(layoutId: string): void
    + openForQuestion(questionId: string, defaultLayoutId?: string): void
    + addNode(parentId: string, node: object): LayoutNode
    + removeNode(nodeId: string): void
    + moveNode(nodeId: string, targetParentId: string, index?: number): void
    + swapNodes(nodeIdA: string, nodeIdB: string): boolean
    + updateNodeProps(nodeId: string, props: object): void
    + reset(): void
    + getResult(): { nodes: LayoutNode[] }
  }
}

' === 通用数据类 ===
class LayoutNode {
  + id: string
  + type: string
  + props: object
  + children: LayoutNode[]
}

' === 关系 ===
PhoneFrame *-- SimNode : 渲染根节点
SimNode o-- LayoutNode : 递归渲染
SimNode --> ComponentLoader : resolveRuntimeComponent
ComponentPanel *-- PanelPreview : 内联定义
PanelPreview --> ComponentLoader : resolveRuntimeComponent
ComponentInfo *-- PropDef : 包含
useSimulatorStore o-- LayoutNode : 管理节点树

note right of SimNode
  容器节点的子节点排序
  由 vuedraggable 处理，
  SimNode 只负责渲染
end note

note right of ComponentPanel
  vuedraggable pull: clone, group: sim
  拖出时 metaToNode() 将
  ComponentInfo 转为 LayoutNode
  直接插入 SimNode 容器的
  node.children 响应式数组
end note

@enduml
